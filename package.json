{
  "name": "@feastalytics/cli",
  "version": "0.1.1",
  "description": "Command-line client for the Feastalytics platform — list, create, and update campaigns, automations, offers, and members-program rewards from the terminal.",
  "type": "module",
  "bin": {
    "feast": "dist/cli.js"
  },
  "files": [
    "dist",
    "feast"
  ],
  "author": "Feastalytics",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/feastalytics/cli.git"
  },
  "homepage": "https://github.com/feastalytics/cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "feast": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@trpc/client": "^10.45.2",
    "@types/node": "^20.14.0",
    "ajv": "^8.17.1",
    "superjson": "^2.2.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.0"
  }
}
